{
  "name": "@convia/api",
  "version": "0.1.0",
  "private": true,
  "description": "Convia NestJS API",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/apps/api/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "clean": "rm -rf dist node_modules",
    "db:generate": "typeorm migration:generate",
    "db:migrate": "typeorm migration:run",
    "db:revert": "typeorm migration:revert",
    "stripe:setup": "ts-node src/scripts/setup-stripe-products.ts"
  },
  "dependencies": {
    "@convia/shared-types": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "3.0.1",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-ws": "11.1.13",
    "@nestjs/schedule": "6.1.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "11.1.13",
    "@pinecone-database/pinecone": "6.1.3",
    "@supabase/supabase-js": "^2.45.0",
    "cheerio": "1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mammoth": "1.11.0",
    "openai": "^4.67.0",
    "pdf-parse": "1.1.1",
    "pg": "^8.12.0",
    "pusher": "^5.2.0",
    "reflect-metadata": "^0.2.2",
    "resend": "6.9.3",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.0",
    "stripe": "^17.5.0",
    "typeorm": "^0.3.20",
    "uuid": "13.0.0",
    "ws": "8.21.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "1.1.5",
    "@types/uuid": "11.0.0",
    "@types/ws": "8.18.1",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
