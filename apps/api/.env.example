# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
API_PORT=9002

# ─── Supabase ────────────────────────────────────────────────
# From Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWT_SECRET=

# ─── Database (Supabase Postgres) ─────────────────────────────
# From Project Settings → Database → Connection string (Session pooler, port 5432)
DATABASE_URL=postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ─── OpenAI (embeddings + LLM) ────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ─── Stripe (billing) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Credential encryption (for channel tokens) ──────────────
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=

# ─── Email (Resend or similar) ───────────────────────────────
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=salut@convia.ro

# ─── App URLs ────────────────────────────────────────────────
NEXT_PUBLIC_LANDING_URL=http://localhost:9000
NEXT_PUBLIC_APP_URL=http://localhost:9001
NEXT_PUBLIC_API_URL=http://localhost:9002
NEXT_PUBLIC_WIDGET_URL=http://localhost:9003
