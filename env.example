# ============================================
# CONVIA ENVIRONMENT VARIABLES
# ============================================

# ============================================
# SUPABASE (Database & Auth)
# ============================================
# Settings → API in your Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co

# New API keys (publishable + secret)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SECRET_KEY=sb_secret_your-key

# JWT secret for backend token verification
SUPABASE_JWT_SECRET=your-jwt-secret

# Frontend (browser-exposed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ============================================
# AI PROVIDERS
# ============================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ============================================
# PROVIDER SELECTION
# ============================================
# Convia runs all-in on Supabase by default: pgvector for RAG, Realtime for
# messaging, Storage for files. The variables below let you swap to alternate
# providers if scale ever demands it. Leave as 'supabase' for MVP.
VECTOR_PROVIDER=supabase
REALTIME_PROVIDER=supabase
NEXT_PUBLIC_REALTIME_PROVIDER=supabase

# ============================================
# OPTIONAL: External vector store (only if VECTOR_PROVIDER=pinecone)
# ============================================
# PINECONE_API_KEY=
# PINECONE_INDEX=convia
# PINECONE_HOST=

# ============================================
# OPTIONAL: External real-time (only if REALTIME_PROVIDER=pusher)
# ============================================
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=eu
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ============================================
# APP URLS & PORTS
# ============================================
# Landing on 3000 (kept from existing setup)
# Dashboard on 3001, API on 3002, Widget on 3003
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WIDGET_URL=http://localhost:3003

API_PORT=3002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# ============================================
# STRIPE (Billing — RON)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Convia plan IDs (set after running the Stripe setup script)
STRIPE_PRICE_BUSINESS_MONTHLY=price_your-business-monthly
STRIPE_PRICE_BUSINESS_YEARLY=price_your-business-yearly
STRIPE_PRICE_BUSINESS_OVERAGE=price_your-business-overage
STRIPE_PRICE_PREMIUM_MONTHLY=price_your-premium-monthly
STRIPE_PRICE_PREMIUM_YEARLY=price_your-premium-yearly
STRIPE_PRICE_PREMIUM_OVERAGE=price_your-premium-overage

STRIPE_METER_BUSINESS=mtr_business-conversations
STRIPE_METER_PREMIUM=mtr_premium-conversations

# Redirects after Stripe Checkout
STRIPE_SUCCESS_URL=http://localhost:3001/settings/billing?success=true
STRIPE_CANCEL_URL=http://localhost:3001/settings/billing?canceled=true

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable

# ============================================
# EMAIL (transactional)
# ============================================
EMAIL_PROVIDER_API_KEY=your-email-provider-key
EMAIL_FROM=salut@convia.ro

# ============================================
# ENCRYPTION
# ============================================
# AES-256-GCM key for encrypting credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=your-64-char-hex-key

# ============================================
# CONVIA-SPECIFIC
# ============================================
# Conversation session timeout in minutes (per-session billing rule)
CONVERSATION_SESSION_TIMEOUT_MINUTES=30

# Free-plan hard cap (conversations per month)
FREE_PLAN_CONVERSATION_CAP=100
